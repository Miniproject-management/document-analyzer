# Database (AWS RDS)
DB_URL=jdbc:mysql://your-rds-endpoint:3306/mini3?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=
DB_PASSWORD=

# JWT (document-analyzer: management-back JwtProvider 와 동일 서명 키)
JWT_SECRET=
JWT_EXPIRATION=3600000

# AWS S3
S3_BUCKET_NAME=

# 프론트 출처 쉼표 구분 (미설정 시 application.yml 기본 = 팀 프론트 ELB)
APP_CORS_ALLOWED_ORIGINS=
